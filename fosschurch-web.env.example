# Copy to "fosschurch-web.env" (gitignored) next to docker-compose.yml and fill
# in the SMTP password for the contact@fosschurch.com mailbox.
#
# This file is loaded by docker-compose with `format: raw`, so values are passed
# to the container verbatim — do NOT quote, and a password containing $ is fine.

FC_SMTP_PASSWORD=replace-with-the-contact@fosschurch.com-mailbox-password

# Optional overrides (defaults shown — usually leave these in docker-compose.yml):
# FC_SMTP_HOST=mail.fosschurch.com
# FC_SMTP_PORT=465
# FC_SMTP_USER=contact@fosschurch.com
# FC_SMTP_FROM=FOSS Church <contact@fosschurch.com>
# FC_ADMIN_EMAILS=jason.matthew.duncan@gmail.com
# FC_AUTOREPLY=true

# Cloudflare Turnstile secret key (pairs with FC_TURNSTILE_SITE_KEY in
# docker-compose.yml). The captcha activates only when both are set.
# FC_TURNSTILE_SECRET=replace-with-the-turnstile-secret-key
